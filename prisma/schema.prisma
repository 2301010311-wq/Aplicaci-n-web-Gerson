generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model detalle_pedidos {
  id             String   @id
  pedidoId       String
  productoId     String
  cantidad       Int
  precioUnitario Float
  subtotal       Float
  createdAt      DateTime @default(now())
}

model ingresos {
  id_ingreso        Int       @id @default(autoincrement())
  fecha_ingreso     DateTime  @default(now()) @db.Timestamp(6)
  monto             Decimal   @db.Decimal(12, 2)
  descripcion       String    @db.VarChar(255)
  categoria         String    @db.VarChar(50)
  cliente           String?   @db.VarChar(100)
  metodo_pago       String    @db.VarChar(50)
  comprobante       String?   @db.VarChar(255)
  estado            String    @default("Registrado") @db.VarChar(20)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model gastos {
  id_gasto          Int       @id @default(autoincrement())
  fecha_gasto       DateTime  @default(now()) @db.Timestamp(6)
  monto             Decimal   @db.Decimal(12, 2)
  categoria         String    @db.VarChar(50)
  proveedor         String?   @db.VarChar(100)
  descripcion       String    @db.VarChar(255)
  comprobante       String?   @db.VarChar(255)
  metodo_pago       String    @db.VarChar(50)
  estado            String    @default("Registrado") @db.VarChar(20)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model facturas {
  id_factura        Int       @id @default(autoincrement())
  numero_factura    String    @unique @db.VarChar(50)
  fecha_emision     DateTime  @default(now()) @db.Timestamp(6)
  fecha_vencimiento DateTime  @db.Timestamp(6)
  cliente           String    @db.VarChar(100)
  monto_total       Decimal   @db.Decimal(12, 2)
  monto_pagado      Decimal   @default(0) @db.Decimal(12, 2)
  estado            String    @default("Pendiente") @db.VarChar(20)
  metodo_pago       String?   @db.VarChar(50)
  descripcion       String?   @db.Text
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model cuentas_por_cobrar {
  id_cobro          Int       @id @default(autoincrement())
  cliente           String    @db.VarChar(100)
  deuda_total       Decimal   @db.Decimal(12, 2)
  deuda_vencida     Decimal   @default(0) @db.Decimal(12, 2)
  fecha_vencimiento DateTime  @db.Timestamp(6)
  estado            String    @default("Pendiente") @db.VarChar(20)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model cuentas_por_pagar {
  id_pago           Int       @id @default(autoincrement())
  proveedor         String    @db.VarChar(100)
  deuda_total       Decimal   @db.Decimal(12, 2)
  deuda_pendiente   Decimal   @db.Decimal(12, 2)
  fecha_vencimiento DateTime  @db.Timestamp(6)
  estado            String    @default("Pendiente") @db.VarChar(20)
  metodo_pago       String?   @db.VarChar(50)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model presupuestos {
  id_presupuesto    Int       @id @default(autoincrement())
  nombre            String    @db.VarChar(100)
  monto_total       Decimal   @db.Decimal(12, 2)
  monto_usado       Decimal   @default(0) @db.Decimal(12, 2)
  categoria         String    @db.VarChar(50)
  fecha_inicio      DateTime  @db.Timestamp(6)
  fecha_fin         DateTime  @db.Timestamp(6)
  estado            String    @default("Activo") @db.VarChar(20)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model movimientos_caja {
  id_movimiento     Int       @id @default(autoincrement())
  fecha             DateTime  @default(now()) @db.Timestamp(6)
  tipo              String    @db.VarChar(20)
  concepto          String    @db.VarChar(100)
  monto             Decimal   @db.Decimal(12, 2)
  saldo_anterior    Decimal   @db.Decimal(12, 2)
  saldo_nuevo       Decimal   @db.Decimal(12, 2)
  descripcion       String?   @db.Text
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model insumos {
  id_insumo         Int      @id @default(autoincrement())
  nombre_insu       String   @db.VarChar(100)
  unidadmedida_insu String   @db.VarChar(20)
  stock_act_insu    Decimal? @default(0) @db.Decimal(10, 2)
  stock_min_insu    Decimal? @default(0) @db.Decimal(10, 2)
  vencimiento_insu  DateTime @db.Date
}

model mesas {
  id_mesa        Int       @id @default(autoincrement())
  numero_mesa    Int       @unique
  capacidad_mesa Int
  estado_mesa    String?   @default("Libre") @db.VarChar(20)
  pedidos        pedidos[]
}

model pedidos {
  id_pedido          Int                @id @default(autoincrement())
  fecha_pedido       DateTime?          @default(now()) @db.Timestamp(6)
  id_user            Int
  id_mesa            Int
  estado_pedido      String?            @default("En preparacion") @db.VarChar(20)
  observaciones      String?            @db.Text
  total              Decimal            @default(0) @db.Decimal(10, 2)
  
  // Auditoría
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  canceledAt         DateTime?
  cancelReason       String?            @db.Text
  
  // Relaciones
  detallepedido      detallepedido[]
  pedido_delivery    pedidos_delivery?
  mesas              mesas              @relation(fields: [id_mesa], references: [id_mesa], onDelete: NoAction, onUpdate: NoAction)
  usuarios           usuarios           @relation(fields: [id_user], references: [id_user], onDelete: NoAction, onUpdate: NoAction)
  
  @@index([fecha_pedido])
  @@index([estado_pedido])
  @@index([id_user])
  @@index([id_mesa])
}

model productos {
  id_produc          Int             @id @default(autoincrement())
  nombre_produc      String          @db.VarChar(100)
  descripcion_produc String?
  precio_produc      Decimal         @db.Decimal(10, 2)
  categoria_produc   String          @db.VarChar(20)
  estado_produc      String?         @default("Activo") @db.VarChar(20)
  vencimiento_produc DateTime        @db.Date
  stock_produc       Int             @default(0)
  controlar_stock    Boolean         @default(true)
  detallepedido      detallepedido[]
}

model usuarios {
  id_user       Int       @id @default(autoincrement())
  nombre_user   String    @db.VarChar(100)
  apellido_user String    @db.VarChar(100)
  dni_user      String?   @unique @db.VarChar(20)
  telefono_user String?   @db.VarChar(20)
  correo_user   String?   @unique @db.VarChar(100)
  rol           String    @db.VarChar(20)
  contrasena    String    @db.VarChar(255)
  pedidos       pedidos[]
}

model detallepedido {
  id_detalle                  Int       @id @default(autoincrement())
  id_pedido                   Int
  id_produc                   Int?
  nombre_produc_personalizado String?   @db.VarChar(255)
  cantidad                    Int       @db.SmallInt
  precio_unitario             Decimal   @db.Decimal(10, 2)
  subtotal                    Decimal   @db.Decimal(10, 2)
  notas                       String?   @db.Text
  estado                      String    @default("Pendiente") @db.VarChar(20)
  
  // Auditoría
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt
  
  // Relaciones
  pedidos                     pedidos   @relation(fields: [id_pedido], references: [id_pedido], onDelete: Cascade, onUpdate: NoAction)
  productos                   productos? @relation(fields: [id_produc], references: [id_produc], onDelete: SetNull, onUpdate: NoAction)
  
  @@index([id_pedido])
  @@index([id_produc])
  @@index([estado])
}

model pedidos_delivery {
  id_delivery      Int       @id @default(autoincrement())
  id_pedido        Int       @unique
  numero_telefono  String    @db.VarChar(20)
  nombre_cliente   String    @db.VarChar(100)
  direccion        String?   @db.Text
  notas            String?   @db.Text
  createdAt        DateTime  @default(now()) @db.Timestamp(6)
  pedidos          pedidos   @relation(fields: [id_pedido], references: [id_pedido], onDelete: Cascade, onUpdate: NoAction)
}

model inventario_pollos {
  id_inventario     Int       @id @default(autoincrement())
  fecha             DateTime  @default(now()) @db.Date
  pollos_totales    Int       @default(0)
  pechos_disponibles Int      @default(0)
  piernas_disponibles Int     @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  @@unique([fecha])
}

model detalle_pollos_pedido {
  id_detalle        Int       @id @default(autoincrement())
  id_pedido         Int
  tipo_presa        String    @db.VarChar(20)
  cantidad          Int
  createdAt         DateTime  @default(now())
}

enum EstadoMesa {
  LIBRE
  OCUPADA
  RESERVADA
}

enum EstadoPedido {
  EN_PREPARACION
  EN_PROCESO
  LISTO_PARA_RECOGER
  SERVIDO
  PAGADO
  CANCELADO
}

enum Rol {
  ADMIN
  MESERO
  COCINERO
  CAJERO
}

enum TipoFinanza {
  INGRESO
  EGRESO
}
