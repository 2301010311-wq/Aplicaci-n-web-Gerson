# ==================== STAGE: TEST RUNNER ====================
# Ejecuta los tests (Jest) en contenedor aislado
FROM node:20-alpine
WORKDIR /app
COPY package*.json ./
RUN npm ci

COPY . .

# Health check para container (verificar que npm test es instalable)
HEALTHCHECK --interval=5s --timeout=3s --retries=3 \
  CMD npm run test -- --listTests > /dev/null 2>&1 || exit 1

# Ejecutar tests con coverage
CMD ["npm", "test", "--", "--coverage", "--passWithNoTests"]
